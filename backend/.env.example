# App
NODE_ENV=development
PORT=3333
CLIENT_URL=http://localhost:5173

# Database
# Dev (padrão): SQLite, zero setup.
DATABASE_URL="file:./dev.db"
# Produção: troque o provider para "postgresql" em prisma/schema.prisma e use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forja?schema=public"

# Auth
JWT_ACCESS_SECRET=troque-por-um-segredo-forte-de-acesso
JWT_REFRESH_SECRET=troque-por-um-segredo-forte-de-refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=10
